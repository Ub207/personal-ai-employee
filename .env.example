# AI Employee — Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Gmail (Bronze + Silver Tier) ─────────────────────────────────────────────
GMAIL_USERNAME=your.email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Email MCP Server (Silver Tier) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password

# Set to "true" for safe testing (emails not actually sent)
DRY_RUN=true

# ── Odoo Community (Gold Tier) ────────────────────────────────────────────────
# Install Odoo 19+ locally: https://www.odoo.com/page/download
ODOO_URL=http://localhost:8069
ODOO_DB=mycompany
ODOO_USERNAME=admin
ODOO_PASSWORD=your-odoo-password

# ── Twitter / X API v2 (Gold Tier) ────────────────────────────────────────────
# Create app at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your-bearer-token
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret

# ── Facebook + Instagram Graph API (Gold Tier) ────────────────────────────────
# Create app at: https://developers.facebook.com/
FB_PAGE_ID=your-page-id
FB_ACCESS_TOKEN=your-page-access-token
IG_ACCOUNT_ID=your-instagram-account-id

# ── Optional ──────────────────────────────────────────────────────────────────
# VAULT_PATH=D:\bronze_tier

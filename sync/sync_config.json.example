{
  "_comment": "Copy to sync_config.json. Never commit this file with real values.",
  "git_remote": "git@github.com:youruser/ai-employee-vault.git",
  "local_agent_id": "local",
  "cloud_agent_id": "cloud",
  "sync_interval_seconds": 300,
  "allowed_extensions": [".md", ".json"],
  "blocked_patterns": [
    ".env", "*.env", ".env.*",
    "*.session", "*.session.json",
    "node_modules", ".venv", "__pycache__",
    "*.pyc", "*.log", "*.lock"
  ],
  "local_vault_path": "D:/bronze_tier",
  "cloud_vault_path": "/opt/ai-employee"
}
